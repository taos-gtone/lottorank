<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:mvc="http://www.springframework.org/schema/mvc"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context.xsd
           http://www.springframework.org/schema/mvc
           http://www.springframework.org/schema/mvc/spring-mvc.xsd">

    <!-- 컴포넌트 스캔 (Controller + Config + Admin Controller) -->
    <context:component-scan base-package="com.lottorank.controller,com.lottorank.config,com.lottorank.admin.controller"/>

    <mvc:interceptors>
        <!-- 세션 자동 갱신 인터셉터: 페이지 이동 시마다 만료 시각 10분 리셋 -->
        <mvc:interceptor>
            <mvc:mapping path="/**"/>
            <mvc:exclude-mapping path="/css/**"/>
            <mvc:exclude-mapping path="/images/**"/>
            <mvc:exclude-mapping path="/resources/**"/>
            <mvc:exclude-mapping path="/member/extend"/>
            <mvc:exclude-mapping path="/uploads/**"/>
            <bean class="com.lottorank.interceptor.SessionRefreshInterceptor"/>
        </mvc:interceptor>
        <!-- 관리자 인증 인터셉터: /lottorank/admin/** 에서 adminUser 세션 없으면 로그인으로 리다이렉트 -->
        <mvc:interceptor>
            <mvc:mapping path="/lottorank/admin/**"/>
            <mvc:exclude-mapping path="/lottorank/admin/login"/>
            <mvc:exclude-mapping path="/css/**"/>
            <bean class="com.lottorank.admin.interceptor.AdminAuthInterceptor"/>
        </mvc:interceptor>
    </mvc:interceptors>

    <!-- Spring MVC 활성화 -->
    <mvc:annotation-driven/>

    <!-- 정적 리소스 매핑 -->
    <mvc:resources mapping="/resources/**" location="/resources/"/>
    <mvc:resources mapping="/images/**" location="/images/"/>
    <mvc:resources mapping="/css/**" location="/css/"/>
    <!-- /uploads/** 는 UploadPathConfig(WebMvcConfigurer)에서 동적으로 등록 -->

    <!-- Multipart 파일 업로드 Resolver -->
    <bean id="multipartResolver"
          class="org.springframework.web.multipart.support.StandardServletMultipartResolver"/>

    <!-- JSP ViewResolver -->
    <bean class="org.springframework.web.servlet.view.InternalResourceViewResolver">
        <property name="prefix" value="/WEB-INF/views/"/>
        <property name="suffix" value=".jsp"/>
        <property name="contentType" value="text/html; charset=UTF-8"/>
    </bean>
</beans>
